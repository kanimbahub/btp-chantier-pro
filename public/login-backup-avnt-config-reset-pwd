<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BTP Chantier Pro — Connexion</title>
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#3dba6a">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="BTP Pro">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
[data-theme="dark"]{--bg:#0e1510;--bg2:#141e15;--bg3:#1a2a1c;--border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.13);--text:#e4ece5;--text2:#7d9e80;--text3:#4a6b4d;}
[data-theme="light"]{--bg:#f4f7f4;--bg2:#ffffff;--bg3:#edf2ed;--border:rgba(0,0,0,0.07);--border2:rgba(0,0,0,0.13);--text:#1a2b1c;--text2:#4a6e4d;--text3:#8aaa8d;}
:root{--green:#3dba6a;--green-l:#eaf7ef;--green-d:#0f2e18;--red:#e8524a;--font:'DM Sans',sans-serif;--radius:10px;--radius-lg:14px;}
*{box-sizing:border-box;margin:0;padding:0;}
button,input{outline:none;font-family:var(--font);}
body{background:var(--bg);color:var(--text);font-family:var(--font);font-size:14px;min-height:100vh;display:flex;align-items:center;justify-content:center;}
.login-wrap{width:100%;max-width:400px;padding:20px;}
.logo-box{text-align:center;margin-bottom:32px;}
.logo-icon{width:56px;height:56px;border-radius:14px;background:var(--green);display:inline-flex;align-items:center;justify-content:center;font-size:28px;margin-bottom:12px;}
.logo-title{font-size:22px;font-weight:600;letter-spacing:-0.5px;}
.logo-sub{font-size:13px;color:var(--text2);margin-top:4px;}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:28px;}
.form-group{margin-bottom:14px;}
.form-group label{font-size:11px;color:var(--text2);display:block;margin-bottom:5px;text-transform:uppercase;letter-spacing:0.4px;}
.form-input{width:100%;background:var(--bg3);border:1px solid var(--border2);color:var(--text);padding:10px 12px;border-radius:var(--radius);font-family:var(--font);font-size:14px;outline:none;transition:border-color 0.2s;}
.form-input:focus{border-color:var(--green);}
.btn-login{width:100%;background:var(--green);color:#fff;border:none;padding:12px;border-radius:var(--radius);font-family:var(--font);font-size:14px;font-weight:600;cursor:pointer;margin-top:6px;transition:opacity 0.15s;}
.btn-login:hover{opacity:0.88;}
.btn-login:disabled{opacity:0.5;cursor:not-allowed;}
.error-box{border-radius:var(--radius);padding:10px 14px;font-size:13px;margin-bottom:14px;display:none;}
.error-box.error{background:rgba(232,82,74,0.1);border:1px solid rgba(232,82,74,0.3);color:var(--red);}
.error-box.success{background:rgba(61,186,106,0.1);border:1px solid rgba(61,186,106,0.3);color:var(--green);}
.contact-box{margin-top:20px;background:var(--bg3);border:1px solid var(--border2);border-radius:var(--radius-lg);padding:20px;text-align:center;}
.contact-box p{font-size:12px;color:var(--text2);margin-bottom:14px;line-height:1.7;}
.contact-box strong{color:var(--text);}
.btn-whatsapp{display:inline-flex;align-items:center;gap:8px;background:#25D366;color:#fff;border:none;padding:10px 20px;border-radius:var(--radius);font-family:var(--font);font-size:13px;font-weight:600;cursor:pointer;transition:opacity 0.15s;text-decoration:none;}
.btn-whatsapp:hover{opacity:0.88;}
.forgot-link{text-align:center;margin-top:14px;font-size:12px;color:var(--text3);cursor:pointer;transition:color 0.15s;}
.forgot-link:hover{color:var(--green);}
.toggle-theme{position:fixed;top:16px;right:16px;background:var(--bg2);border:1px solid var(--border2);color:var(--text2);padding:6px 12px;border-radius:20px;font-size:12px;cursor:pointer;}
</style>
</head>
<body>
<button class="toggle-theme" onclick="toggleTheme()" id="theme-btn">☀️ Clair</button>
<div class="login-wrap">
  <div class="logo-box">
    <div class="logo-icon">🏗</div>
    <div class="logo-title">BTP Chantier Pro</div>
    <div class="logo-sub">Afrique de l'Ouest — Gestion de chantiers</div>
  </div>
  <div class="card">
    <div class="error-box" id="error-box"></div>
    <div class="form-group">
      <label>Email</label>
      <input type="email" id="email" class="form-input" placeholder="admin@btppro.gn" autocomplete="email">
    </div>
    <div class="form-group">
      <label>Mot de passe</label>
      <input type="password" id="password" class="form-input" placeholder="••••••••" autocomplete="current-password">
    </div>
    <button class="btn-login" id="btn-login" onclick="login()">Se connecter →</button>
    <div class="forgot-link" onclick="resetPassword()">Mot de passe oublié ?</div>
  </div>

  <div class="contact-box">
    <p>Vous n'avez pas encore de compte ?<br><strong>Contactez-nous pour accéder à BTP Chantier Pro.</strong></p>
    <a class="btn-whatsapp" href="https://wa.me/33605510102?text=Bonjour%2C%20je%20souhaite%20acc%C3%A9der%20%C3%A0%20BTP%20Chantier%20Pro" target="_blank">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Nous contacter sur WhatsApp
    </a>
  </div>
</div>

<script>
const{createClient}=supabase
const db=createClient('https://aktwkafyzrujqgvojolx.supabase.co','eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFrdHdrYWZ5enJ1anFndm9qb2x4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM2OTY2MDAsImV4cCI6MjA4OTI3MjYwMH0.OLBuhijTx3lRK5VofjxmoplGgQ1UsxbgIs3igj2hGpM')

function toggleTheme(){
  const h=document.documentElement,d=h.dataset.theme==='dark'
  h.dataset.theme=d?'light':'dark'
  document.getElementById('theme-btn').textContent=d?'🌙 Sombre':'☀️ Clair'
}

function showMsg(msg,type='error'){
  const el=document.getElementById('error-box')
  el.className='error-box '+type
  el.textContent=msg
  el.style.display='block'
}
function hideMsg(){document.getElementById('error-box').style.display='none'}

async function login(){
  const email=document.getElementById('email').value
  const password=document.getElementById('password').value
  if(!email||!password){showMsg('Email et mot de passe obligatoires');return}
  const btn=document.getElementById('btn-login')
  btn.disabled=true;btn.textContent='Connexion...'
  hideMsg()
  const{error}=await db.auth.signInWithPassword({email,password})
  if(error){
    showMsg(error.message==='Invalid login credentials'?'Email ou mot de passe incorrect':error.message)
    btn.disabled=false;btn.textContent='Se connecter →'
    return
  }
  window.location.href='index.html'
}

async function resetPassword(){
  const email=document.getElementById('email').value
  if(!email){showMsg('Entrez votre email d\'abord');return}
  const{error}=await db.auth.resetPasswordForEmail(email,{redirectTo:window.location.origin+'/index.html'})
  if(error){showMsg(error.message);return}
  showMsg('Email de réinitialisation envoyé ! Vérifiez votre boîte mail.','success')
}

db.auth.getSession().then(({data:{session}})=>{
  if(session) window.location.href='index.html'
})

document.addEventListener('keydown',e=>{
  if(e.key==='Enter') login()
})
</script>
<script>if("serviceWorker" in navigator){navigator.serviceWorker.register("/sw.js").catch(()=>{})}</script>
</body>
</html>
